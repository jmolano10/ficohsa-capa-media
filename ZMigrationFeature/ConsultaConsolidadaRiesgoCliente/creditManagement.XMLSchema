                                        minOccurs="0" />
                                      <xsd:element name="IntraBalance" type="xsd:string"
                                        minOccurs="0" />
                                      <xsd:element name="element91" type="xsd:string" minOccurs="0" />
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="FlagCollaborator" type="xsd:string" minOccurs="0" />
                        </xsd:sequence>
                      </xsd:complexType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
              <xsd:element name="LoansInfo" minOccurs="0">
