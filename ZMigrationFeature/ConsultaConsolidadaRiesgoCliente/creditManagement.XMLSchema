                          <xsd:element name="CurrentBalance" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="PaymentAmount" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="Rate" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="Term" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="PaymentNumber" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="FirstPaymentDate" minOccurs="0" type="xsd:string" />
                          <xsd:element name="PaidPayments" minOccurs="0" type="xsd:string" />
                          <xsd:element name="CapitalFrequency" minOccurs="0" type="xsd:string" />
                          <xsd:element name="DestinationCode" minOccurs="0" type="xsd:string" />
                          <xsd:element name="MonthlyPrime" minOccurs="0" type="xsd:string" />
                          <xsd:element name="ContractNumber" minOccurs="0" type="xsd:integer" />
                          <xsd:element name="Charges" type="xsd:decimal" minOccurs="0" />
                          <xsd:element name="Interest" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="Insurance" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="OtherCharges" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="CurrentDue" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="DebtorType" minOccurs="0" type="xsd:string" />
                          <xsd:element name="CodeType" minOccurs="0" type="xsd:string" />
                          <xsd:element name="GuaranteeType" minOccurs="0" type="xsd:string" />
                          <xsd:element name="ProductTransactions" minOccurs="0">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="Transaction" minOccurs="0" maxOccurs="unbounded">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="PeriodDate" type="xsd:string" minOccurs="0" />
                                      <xsd:element name="PeriodBalance" type="xsd:decimal"
                                        minOccurs="0" />
                                      <xsd:element name="CapitalBalance" type="xsd:decimal"
                                        minOccurs="0" />
                                      <xsd:element name="DueBalance" type="xsd:decimal"
                                        minOccurs="0" />
                                      <xsd:element name="Charges" type="xsd:string" minOccurs="0" />
                                      <xsd:element name="Interest" type="xsd:string" minOccurs="0" />
                                      <xsd:element name="Payment" type="xsd:string" minOccurs="0" />
                                      <xsd:element name="Insurance" type="xsd:string" minOccurs="0" />
                                      <xsd:element name="OtherCharges" type="xsd:string"
                                        minOccurs="0" />
                                      <xsd:element name="CycleDue" type="xsd:string" minOccurs="0" />
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
