                          <xsd:element name="SubApplication" minOccurs="0" type="xsd:string" />
                          <xsd:element name="OpeningDate" minOccurs="0" type="xsd:string" />
                          <xsd:element name="CancelationDate" minOccurs="0" type="xsd:string" />
