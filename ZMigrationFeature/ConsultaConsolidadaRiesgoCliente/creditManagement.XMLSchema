                          <xsd:element name="CashDiscountDate" type="xsd:string" minOccurs="0" />
                          <xsd:element name="LockCode1" type="xsd:string" minOccurs="0" />
                          <xsd:element name="LockCode2" type="xsd:string" minOccurs="0" />
                          <xsd:element name="Logo" type="xsd:string" minOccurs="0" />
                          <xsd:element name="AvailableCash" type="xsd:string" minOccurs="0" />
                          <xsd:element name="LockDate1" type="xsd:string" minOccurs="0" />
                          <xsd:element name="LockDate2" type="xsd:string" minOccurs="0" />
