                    <xsd:element name="CancelationDate" minOccurs="0" type="xsd:string" />
                    <xsd:element name="InitialAmount" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="CurrentBalance" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="PaymentAmount" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="Rate" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="Term" minOccurs="0" type="xsd:integer" />
                    <xsd:element name="PaymentNumber" minOccurs="0" type="xsd:integer" />
