                          <xsd:element name="QualificationScore" minOccurs="0" type="xsd:string" />
                          <xsd:element name="QualificationCustomerScore" minOccurs="0"
                            type="xsd:string" />
                          <xsd:element name="Status" minOccurs="0" type="xsd:string" />
                          <xsd:element name="AffinityGroup" minOccurs="0" type="xsd:string" />
                          <xsd:element name="Product" minOccurs="0" type="xsd:string" />
                          <xsd:element name="ClearingModel" type="xsd:string" minOccurs="0" />
                          <xsd:element name="OpeningDate" minOccurs="0" type="xsd:string" />
                          <xsd:element name="CancelationDate" minOccurs="0" type="xsd:string" />
                          <xsd:element name="LastExtraDate" minOccurs="0" type="xsd:string" />
