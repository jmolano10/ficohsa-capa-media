                                      <xsd:element name="TotalFees" type="xsd:string" minOccurs="0" />
                                      <xsd:element name="OtherDebits" type="xsd:string"
                                        minOccurs="0" />
                                      <xsd:element name="CycleDue" type="xsd:string" minOccurs="0" />
