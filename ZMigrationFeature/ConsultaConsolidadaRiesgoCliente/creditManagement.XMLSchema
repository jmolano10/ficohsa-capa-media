                          <xsd:element name="For96Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For108Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For120Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="ForMaxAmount" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="MegOffer" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="MaxOffer" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="NdeOffer" minOccurs="0" type="xsd:decimal" />
