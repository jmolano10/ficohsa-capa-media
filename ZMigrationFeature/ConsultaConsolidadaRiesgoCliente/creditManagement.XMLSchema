        <xsd:element name="ReferencesDetails" minOccurs="0">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="Queries" minOccurs="0">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="QueryItem" maxOccurs="unbounded" minOccurs="0">
                      <xsd:complexType>
                        <xsd:sequence>
