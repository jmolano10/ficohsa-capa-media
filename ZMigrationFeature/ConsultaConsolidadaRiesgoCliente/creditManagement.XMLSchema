              <xsd:element name="Target" minOccurs="0" type="xsd:string" />
              <xsd:element name="DateOfBirth" minOccurs="0" type="xsd:string" />
              <xsd:element name="Age" minOccurs="0" type="xsd:integer" />
              <xsd:element name="Gender" minOccurs="0" type="xsd:string" />
              <xsd:element name="Type" minOccurs="0" type="xsd:string" />
              <xsd:element name="TotalSalary" minOccurs="0" type="xsd:decimal" default="0" />
              <xsd:element name="NetSalary" minOccurs="0" type="xsd:decimal" default="0" />
              <xsd:element name="PayrollSalary" default="0" type="xsd:decimal" minOccurs="0" />
              <xsd:element name="CreditMonths" default="0" minOccurs="0" type="xsd:integer" />
              <xsd:element name="FlagHit" type="xsd:string" minOccurs="0" />
              <xsd:element name="LaborYears" minOccurs="0" type="xsd:string" />
              <xsd:element name="JobCompany" type="xsd:string" minOccurs="0" />
              <xsd:element name="JobType" minOccurs="0" type="xsd:string" />
              <xsd:element name="JobCharge" minOccurs="0" type="xsd:string" />
              <xsd:element name="JobStartDate" minOccurs="0" type="xsd:string" />
              <xsd:element name="SourceOfIncome" minOccurs="0" type="xsd:string" />
              <xsd:element name="FicohsaProduct" minOccurs="0" type="xsd:string" />
              <xsd:element name="InternalClientType" minOccurs="0" type="xsd:string" />
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="ExternalScore" minOccurs="0" type="xsd:decimal" />
        <xsd:element name="ScoreInfo" minOccurs="0">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="ScoreCalculation" minOccurs="0" type="xsd:integer" />
              <xsd:element name="Qualification" minOccurs="0" type="xsd:string" />
              <xsd:element name="RiskLevel" minOccurs="0" type="xsd:string" />
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="Offers" minOccurs="0">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="Offer" minOccurs="0" maxOccurs="unbounded">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="ProductCode" minOccurs="0" type="xsd:string" />
                    <xsd:element name="MaxAmount" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="Installment" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="Rate" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="AmountCalculations" minOccurs="0">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element name="For12Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For18Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For24Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For36Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For48Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For60Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For180Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For120Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For72Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For84Months" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="For96Months" minOccurs="0" type="xsd:decimal" />
                        </xsd:sequence>
                      </xsd:complexType>
                    </xsd:element>
                    <xsd:element name="TimesIncome" minOccurs="0" type="xsd:integer" />
                    <xsd:element name="Resolution" minOccurs="0">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element name="Code" type="xsd:string" minOccurs="0" />
                          <xsd:element name="Description" type="xsd:string" minOccurs="0" />
                        </xsd:sequence>
                      </xsd:complexType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="Assets" minOccurs="0">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="Asset" maxOccurs="unbounded" minOccurs="0">
                <xsd:complexType>
                  <xsd:sequence>
                    <xsd:element name="Number" minOccurs="0" type="xsd:string" />
                    <xsd:element name="Category" minOccurs="0" type="xsd:integer" />
                    <xsd:element name="Currency" minOccurs="0" type="xsd:string" />
                    <xsd:element name="OpeningDate" minOccurs="0" type="xsd:string" />
                    <xsd:element name="CancelationDate" minOccurs="0" type="xsd:string" />
                    <xsd:element name="CurrentBalance" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="EndOfMonthBalance" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="AverageBalance" minOccurs="0" type="xsd:decimal" />
                    <xsd:element name="LiabilitiesTransactions" minOccurs="0" maxOccurs="unbounded">
                      <xsd:complexType>
                        <xsd:sequence>
                          <xsd:element name="Account" minOccurs="0" type="xsd:string" />
