  <xsd:import schemaLocation="../../../../CommonResources/XSD/CommonTypes.xsd"
    namespace="http://www.ficohsa.com.hn/middleware.services/commonTypes" />
  <xsd:element name="getConsolidatedCustomerRiskResponse">
    <xsd:annotation>
      <xsd:documentation>A sample element</xsd:documentation>
    </xsd:annotation>
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="StatusInfo" type="dtt:StatusInfoType" minOccurs="0" />
        <xsd:element name="ErrorInfo" type="dtt:ErrorInfoType" minOccurs="0" />
        <xsd:element name="GetConsolidatedCustomerRisk" minOccurs="0">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="LoanMaintenance" minOccurs="0">
