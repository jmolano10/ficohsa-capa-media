                          <xsd:element name="DateOfBirth" minOccurs="0" type="xsd:string" />
                          <xsd:element name="Age" minOccurs="0" type="xsd:string" />
                          <xsd:element name="Gender" minOccurs="0" type="xsd:string" />
                          <xsd:element name="Type" minOccurs="0" type="xsd:string" />
                          <xsd:element name="Salary" minOccurs="0" type="xsd:string" />
                          <xsd:element name="PayRollSalary" minOccurs="0" type="xsd:string" />
                          <xsd:element name="CreditMonths" minOccurs="0" type="xsd:string" />
                          <xsd:element name="FlagBlaze" minOccurs="0" type="xsd:string" />
                          <xsd:element name="FlagHit" minOccurs="0" type="xsd:string" />
                          <xsd:element name="EvaluationNumberTuca" default="0" type="xsd:string"
                            minOccurs="0" />
                          <xsd:element name="EvaluationNumberSirc" default="0" minOccurs="0"
                            type="xsd:string" />
                          <xsd:element name="EvaluationResult" minOccurs="0" type="xsd:string" />
                          <xsd:element name="AddressesInfo" maxOccurs="1" minOccurs="0">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="AddressItem" minOccurs="0" maxOccurs="unbounded">
                                  <xsd:complexType>
                                    <xsd:sequence>
                                      <xsd:element name="Period" minOccurs="0" type="xsd:string" />
                                      <xsd:element name="Address" minOccurs="0" type="xsd:string" />
                                    </xsd:sequence>
                                  </xsd:complexType>
                                </xsd:element>
                              </xsd:sequence>
                            </xsd:complexType>
                          </xsd:element>
                          <xsd:element name="PhonesInfo" minOccurs="0">
                            <xsd:complexType>
                              <xsd:sequence>
                                <xsd:element name="PhoneItem" minOccurs="0" maxOccurs="unbounded">
                                  <xsd:complexType>
                                    <xsd:sequence>
