                          <xsd:element name="CurrentLimit" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="CurrentBalance" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="ClosingBalance" type="xsd:string" minOccurs="0" />
                          <xsd:element name="ExtraBalance" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="IntraBalance" minOccurs="0" type="xsd:decimal" />
                          <xsd:element name="ActiveExtraInstallments" minOccurs="0"
