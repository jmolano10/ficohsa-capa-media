                          <xsd:element name="FlagJointAccount" minOccurs="0" type="xsd:string" />
                          <xsd:element name="FlagPayrollAccount" minOccurs="0" type="xsd:string" />
                          <xsd:element name="FlagAccountFacilities" minOccurs="0" type="xsd:string" />
                          <xsd:element name="FlagLegalRepresentative" minOccurs="0"
                            type="xsd:string" />
                          <xsd:element name="AmountCreditPayrollAccount" minOccurs="0"
                            type="xsd:string" />
                          <xsd:element name="AmountCredits" minOccurs="0" type="xsd:string" />
                          <xsd:element name="AmountDebits" minOccurs="0" type="xsd:string" />
                          <xsd:element name="InterestAmountCredits" minOccurs="0" type="xsd:string" />
                          <xsd:element name="InterestAmountDebits" minOccurs="0" type="xsd:string" />
                          <xsd:element name="NumberOfCredits" minOccurs="0" type="xsd:string" />
                          <xsd:element name="NumberOfDebits" minOccurs="0" type="xsd:string" />
                          <xsd:element name="NumberOfInterestsCredits" minOccurs="0"
                            type="xsd:string" />
                          <xsd:element name="NumberOfInterestDebits" minOccurs="0" type="xsd:string" />
                          <xsd:element name="EndBalance" minOccurs="0" type="xsd:string" />
                          <xsd:element name="MaxBalance" minOccurs="0" type="xsd:string" />
                          <xsd:element name="MinBalance" minOccurs="0" type="xsd:string" />
                          <xsd:element name="AverageBalance" minOccurs="0" type="xsd:string" />
                        </xsd:sequence>
                      </xsd:complexType>
                    </xsd:element>
                  </xsd:sequence>
                </xsd:complexType>
              </xsd:element>
            </xsd:sequence>
          </xsd:complexType>
        </xsd:element>
        <xsd:element name="Asset" maxOccurs="unbounded" minOccurs="0">
          <xsd:complexType>
            <xsd:sequence>
              <xsd:element name="Number" minOccurs="0" type="xsd:string" />
              <xsd:element name="Category" minOccurs="0" type="xsd:integer" />
              <xsd:element name="Currency" minOccurs="0" type="xsd:string" />
