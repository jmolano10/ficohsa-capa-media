<?xml version="1.0" encoding="UTF-8"?>
<con:schemaEntry xmlns:con="http://www.bea.com/wli/sb/resources/config">
    <con:schema><![CDATA[<xsd:schema targetNamespace="http://www.ficohsa.com.hn/middleware.services/creditManagement"
  elementFormDefault="qualified" xmlns:xsd="http://www.w3.org/2001/XMLSchema"
  xmlns:dtt="http://www.ficohsa.com.hn/middleware.services/commonTypes"
