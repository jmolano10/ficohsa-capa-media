flowchart TD
    A[Cliente CB] --> B[ValidaDepositoReferenciadoCB Proxy]
    
    B --> C{Validar Esquema XML}
    C -->|Error| D[Error Handler - BEA-382505]
    D --> E[mapeoErrorValidate]
    E --> F[SOAP Fault al Cliente]
    
    C -->|OK| G{Validar Campos Obligatorios}
    G -->|ACCOUNT vacío| H[Error: NO ACCOUNT]
    G -->|TYPE vacío| I[Error: NO DOCUMENT TYPE]
    G -->|VALUE vacío| J[Error: NO DOCUMENT VALUE]
    H --> K[MapeoErrores - FICBCO0312]
    I --> K
    J --> K
    K --> L[Response con Error]
    
    G -->|OK| M[Validar Corresponsal Bancario]
    M --> N[consultarCorresponsalB_db]
    N --> O{PV_CODIGO_MENSAJE = SUCCESS?}
    O -->|No| P[Construir Header Error]
    P --> Q[Response Error Corresponsal]
    
    O -->|Sí| R[Eliminar BankingCorrespondent Header]
    R --> S[Invocar DepositosReferenciados]
    
    S --> T[DepositosReferenciados Router]
    T --> U{Enrutamiento por Operación}
    U -->|validaDepositoReferenciado| V[Route a ValidaDepositoReferenciado]
    U -->|Otras operaciones| W[Otras rutas]
    
    V --> X[ValidaDepositoReferenciado Proxy]
    X --> Y{Validar Esquema Core}
    Y -->|Error| Z[Error Handler Core]
    
    Y -->|OK| AA{Validar Campos Core}
    AA -->|Error| Z
    
    AA -->|OK| BB[Validar Servicio Regional]
    BB --> CC[ValidaServicioRegional_db]
    CC --> DD{PV_CODIGO_ERROR = SUCCESS?}
    DD -->|No| EE[Header Error Regional]
    EE --> FF[Response Error Servicio]
    
    DD -->|Sí| GG{Enrutamiento Regional}
    GG -->|SourceBank = HN01| HH[Pipeline HN01]
    GG -->|Otras regiones| II[Pipeline DefaultBranch]
    
    II --> JJ[Error MW-0008]
    JJ --> KK[SERVICE NOT IMPLEMENTED]
    
    HH --> LL[Invocar ValidaDepositoReferenciado_db]
    LL --> MM[CBR_K_DEP_REFERENCIADOS.CRB_P_VALIDAR_DEPOSITO_REF]
    MM --> NN[Conexión: eis/DB/ConnectionProxyAbanksHN]
    
    NN --> OO{PV_CODIGO_RETORNO = -1?}
    OO -->|Sí| PP[Error: NO RECORDS]
    PP --> QQ[MapeoErrores - FICBCO0311]
    
    OO -->|No| RR[Procesar ResultSet]
    RR --> SS[Transformar con validaDepositoReferenciadoOUT.xq]
    SS --> TT[Mapear Arrays de Deudores]
    
    TT --> UU[Construir Header SUCCESS]
    UU --> VV[Response Core Exitoso]
    
    VV --> WW[Retorno a DepositosReferenciados]
    WW --> XX[Retorno a ValidaDepositoReferenciadoCB]
    
    XX --> YY{successIndicator = SUCCESS?}
    YY -->|No| ZZ[MapeoErrores - FICBCO0312]
    ZZ --> AAA[Response CB Error]
    
    YY -->|Sí| BBB[Transformar con validaDepositoReferenciadoCBOUT.xq]
    BBB --> CCC[Aplanar Estructura DEBTOR_INFOS]
    CCC --> DDD[SOAP Response Exitoso]
    
    DDD --> EEE[Cliente CB]
    L --> EEE
    Q --> EEE
    FF --> EEE
    KK --> EEE
    QQ --> EEE
    AAA --> EEE
    F --> EEE
    
