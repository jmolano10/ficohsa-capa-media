                <con:stage id="_StageId-N53e8b9dc.N41373bfe.0.189f609faa7.N7ec5" name="StageInvokeCoreBanking">
                    <con:context/>
                    <con:actions>
                        <con1:wsCallout xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7ec2</con2:id>
                            <con1:service ref="SBHN_Transfer_RollbackTaxesBullletin/BS/ReversarTransaccionSoapT24BS" xsi:type="ref:BusinessServiceRef" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
