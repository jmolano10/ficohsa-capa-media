                    <con:context>
                        <con1:userNsDecl prefix="tran" namespace="https://www.ficohsa.com/regional/transfer/transferTypes" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                    </con:context>
                    <con:actions>
