<application xmlns:soa="http://www.oracle.com/soa/rest" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://wadl.dev.java.net/2009/02">
   <doc title="RollbackTaxesBulletinRestPS">RestService</doc>
   <grammars>
      <xsd:schema xmlns:tns="https://www.ficohsa.com/regional/transfer/transferTypes" xmlns:inp1="https://www.ficohsa.com/regional/transfer/transferTypes" xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/" xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/">
            <xsd:import namespace="https://www.ficohsa.com/regional/transfer/transferTypes" schemaLocation="../Schemas/RollbackTaxesBulletinTypes.xsd"/>
        </xsd:schema>
   </grammars>
   <resources>
      <resource path="/">
         <method name="POST" soa:wsdlOperation="rollbackTaxesBulletin">
            <request>
               <representation mediaType="application/xml" element="cns:rollbackTaxesBullletin" xmlns:cns="https://www.ficohsa.com/regional/transfer/transferTypes"/>
               <representation mediaType="application/json" element="cns:rollbackTaxesBullletin" xmlns:cns="https://www.ficohsa.com/regional/transfer/transferTypes"/>
            </request>
            <response status="200">
               <representation mediaType="application/xml" element="cns:rollbackTaxesBullletinResponse" xmlns:cns="https://www.ficohsa.com/regional/transfer/transferTypes"/>
               <representation mediaType="application/json" element="cns:rollbackTaxesBullletinResponse" xmlns:cns="https://www.ficohsa.com/regional/transfer/transferTypes"/>
            </response>
         </method>
      </resource>
   </resources>
</application>