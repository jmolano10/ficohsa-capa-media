<?xml version="1.0" encoding="UTF-8"?>
<con:pipelineEntry xmlns:con="http://www.bea.com/wli/sb/pipeline/config" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
    <con:coreEntry>
        <con:binding type="SOAP" isSoap12="false" xsi:type="con:SoapBindingType">
            <con:wsdl ref="SBHN_Transfer_GetTicket/Resources/GetTicket"/>
            <con:binding>
                <con:name>getTicketBind</con:name>
                <con:namespace>https://www.ficohsa.com/regional/transfer</con:namespace>
            </con:binding>
        </con:binding>
        <con:xqConfiguration>
            <con:snippetVersion>1.0</con:snippetVersion>
        </con:xqConfiguration>
    </con:coreEntry>
    <con:router>
        <con:template-overrides>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f97">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">'Transfer/GetTicket'</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f60">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">'v1'</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f5c">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">'Ticket'</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f59">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">data($body/tran:getTicket/Ticket/text())</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f56">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">'SOAP'</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f53">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">'ObtenerTicketSoapT24BS.'</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f50">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">'T24'</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f4d">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">'Y'</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
            <con:stage-override id="_StageId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f9d">
                <con:context>
                    <con1:userNsDecl prefix="tran" namespace="https://www.ficohsa.com/regional/transfer" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                </con:context>
            </con:stage-override>
            <con:placeholder-override id="PlaceholderID_N53e8b9dc.N41373bfe.0.189f609faa7.N7f46">
                <con:stage id="_StageId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ed7" name="StageSecurity">
                    <con:context/>
                    <con:actions>
                        <con1:assign varName="userName" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ed4</con2:id>
                            <con1:expr>
                                <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">&lt;userLoginElement xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"                  
                  xmlns="https://www.ficohsa.com/honduras/user">
  &lt;userLogin>{$user}&lt;/userLogin>
&lt;/userLoginElement></con2:xqueryText>
                            </con1:expr>
                        </con1:assign>
                        <con1:replace varName="responseUserLogin" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ed1</con2:id>
                            <con1:expr>
                                <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                    <con2:resource ref="SBHN_Transfer_Commons/Transformations/ExtractCredentials"/>
                                    <con2:param name="account">
                                        <con2:path>$userName</con2:path>
                                    </con2:param>
                                </con2:xqueryTransform>
                            </con1:expr>
                        </con1:replace>
                    </con:actions>
                </con:stage>
            </con:placeholder-override>
            <con:placeholder-override id="PlaceholderID_N53e8b9dc.N41373bfe.0.189f609faa7.N7f45">
                <con:stage id="_StageId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ed0" name="StageTransformRequest">
                    <con:context>
                        <con1:userNsDecl prefix="tran" namespace="https://www.ficohsa.com/regional/transfer" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                    </con:context>
                    <con:actions>
                        <con1:replace varName="requestService" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ecd</con2:id>
                            <con1:expr>
                                <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                    <con2:resource ref="SBHN_Transfer_GetTicket/Transformations/GetTicketToT24"/>
                                    <con2:param name="input">
                                        <con2:path>$body/tran:getTicket</con2:path>
                                    </con2:param>
                                    <con2:param name="userConnInfo">
                                        <con2:path>$responseUserLogin</con2:path>
                                    </con2:param>
                                </con2:xqueryTransform>
                            </con1:expr>
                        </con1:replace>
                    </con:actions>
                </con:stage>
            </con:placeholder-override>
            <con:placeholder-override id="PlaceholderID_N53e8b9dc.N41373bfe.0.189f609faa7.N7f44">
                <con:stage id="_StageId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ecc" name="StageInvokeCoreBanking">
                    <con:context/>
                    <con:actions>
                        <con1:wsCallout xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ec9</con2:id>
                            <con1:service ref="SBHN_Transfer_GetTicket/BS/ObtenerTicketSoapT24BS" xsi:type="ref:BusinessServiceRef" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
                            <con1:operation>getTicket</con1:operation>
                            <con1:request>
                                <con1:body wrapped="false">requestService</con1:body>
                            </con1:request>
                            <con1:response>
                                <con1:body wrapped="false">responseService</con1:body>
                            </con1:response>
                            <con1:requestTransform/>
                            <con1:responseTransform>
                                <con1:replace varName="statusService">
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ec0</con2:id>
                                    <con1:expr>
                                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">let $successIndicator:= $responseService/Status/successIndicator/text()
return
if ($successIndicator = "Success") then (
   if ((fn:string($responseService/WSQRYTICKETType/ZERORECORDS/text())!= "")) then ( 
     "Error"
   ) else $successIndicator
) else 
  'Error'</con2:xqueryText>
                                    </con1:expr>
                                </con1:replace>
                                <con1:replace varName="codeErrorService">
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ec3</con2:id>
                                    <con1:expr>
                                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">let $successIndicator:= $responseService/Status/successIndicator/text()
return
if ($successIndicator = "Success") then (
   if ((fn:string($responseService/WSQRYTICKETType/ZERORECORDS/text())!= "")) then ( 
     "Error"
   ) else $successIndicator
) else 
  $successIndicator</con2:xqueryText>
                                    </con1:expr>
                                </con1:replace>
                                <con1:replace varName="messageErrorService">
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ec6</con2:id>
                                    <con1:expr>
                                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">let $successIndicator:= $responseService/Status/successIndicator/text()
return
if ($successIndicator = "Success") then (
   if ((fn:string($responseService/WSQRYTICKETType/ZERORECORDS/text())!= "")) then ( 
     (fn:string($responseService/WSQRYTICKETType/ZERORECORDS/text()))
   ) else $responseService/Status/messages/text()
) else
  $responseService/Status/messages/text()</con2:xqueryText>
                                    </con1:expr>
                                </con1:replace>
                            </con1:responseTransform>
                        </con1:wsCallout>
                    </con:actions>
                </con:stage>
            </con:placeholder-override>
            <con:placeholder-override id="PlaceholderID_N53e8b9dc.N41373bfe.0.189f609faa7.N7f64">
                <con:stage id="_StageId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ebf" name="StageTargetSystemToRegional">
                    <con:context>
                        <con1:userNsDecl prefix="tran" namespace="https://www.ficohsa.com/regional/transfer" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                    </con:context>
                    <con:actions>
                        <con1:ifThenElse xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7eb8</con2:id>
                            <con1:case id="_BranchId-N53e8b9dc.2e486765.0.18ceed38bc6.N7eb7">
                                <con1:condition>
                                    <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">$codeErrorService = 'Success'</con2:xqueryText>
                                </con1:condition>
                                <con1:actions>
                                    <con1:replace varName="body" contents-only="true">
                                        <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7eae</con2:id>
                                        <con1:expr>
                                            <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                                <con2:resource ref="SBHN_Transfer_GetTicket/Transformations/T24ToGetTicket"/>
                                                <con2:param name="coreResponse">
                                                    <con2:path>$responseService</con2:path>
                                                </con2:param>
                                                <con2:param name="globalId">
                                                    <con2:path>data($originalBody//GeneralInfo/GlobalId)</con2:path>
                                                </con2:param>
                                            </con2:xqueryTransform>
                                        </con1:expr>
                                    </con1:replace>
                                </con1:actions>
                            </con1:case>
                            <con1:default>
                                <con1:wsCallout>
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7eb4</con2:id>
                                    <con1:service ref="SBHN_Transfer_Commons/BS/GetCustomErrorByStackTraceRegionalRestBS" xsi:type="ref:BusinessServiceRef" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
                                    <con1:operation>process</con1:operation>
                                    <con1:request>
                                        <con1:body wrapped="false">requestError</con1:body>
                                    </con1:request>
                                    <con1:response>
                                        <con1:body wrapped="false">responseError</con1:body>
                                    </con1:response>
                                    <con1:requestTransform>
                                        <con1:replace varName="requestError">
                                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7eb1</con2:id>
                                            <con1:expr>
                                                <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                                    <con2:resource ref="SBHN_Transfer_Commons/Transformations/ServicesToError"/>
                                                    <con2:param name="systemApplication">
                                                        <con2:path>$targetSystem</con2:path>
                                                    </con2:param>
                                                    <con2:param name="service">
                                                        <con2:path>$service</con2:path>
                                                    </con2:param>
                                                    <con2:param name="errorMessage">
                                                        <con2:path>$messageErrorService</con2:path>
                                                    </con2:param>
                                                    <con2:param name="errorCode">
                                                        <con2:path>$codeErrorService</con2:path>
                                                    </con2:param>
                                                    <con2:param name="language">
                                                        <con2:path>data($body/tran:getTicket/GeneralInfo/Language/text())</con2:path>
                                                    </con2:param>
                                                </con2:xqueryTransform>
                                            </con1:expr>
                                        </con1:replace>
                                    </con1:requestTransform>
                                    <con1:responseTransform/>
                                </con1:wsCallout>
                                <con1:replace varName="body" contents-only="true">
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7eab</con2:id>
                                    <con1:expr>
                                        <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                            <con2:resource ref="SBHN_Transfer_GetTicket/Transformations/ErrorToGetTicket"/>
                                            <con2:param name="responseError">
                                                <con2:path>$responseError</con2:path>
                                            </con2:param>
                                            <con2:param name="globalId">
                                                <con2:path>data($originalBody//GeneralInfo/GlobalId)</con2:path>
                                            </con2:param>
                                            <con2:param name="codeError">
                                                <con2:path>$codeErrorService</con2:path>
                                            </con2:param>
                                            <con2:param name="messageError">
                                                <con2:path>$messageErrorService</con2:path>
                                            </con2:param>
                                            <con2:param name="targetSystem">
                                                <con2:path>$targetSystem</con2:path>
                                            </con2:param>
                                            <con2:param name="status">
                                                <con2:path>$statusService</con2:path>
                                            </con2:param>
                                        </con2:xqueryTransform>
                                    </con1:expr>
                                </con1:replace>
                            </con1:default>
                        </con1:ifThenElse>
                    </con:actions>
                </con:stage>
            </con:placeholder-override>
            <con:placeholder-override id="PlaceholderID_N53e8b9dc.N41373bfe.0.189f609faa7.N7f37">
                <con:stage id="_StageId-N53e8b9dc.2e486765.0.18ceed38bc6.N7eaa" name="ErrorToResponse">
                    <con:context/>
                    <con:actions>
                        <con1:replace varName="body" contents-only="true" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8b9dc.2e486765.0.18ceed38bc6.N7ea7</con2:id>
                            <con1:expr>
                                <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                    <con2:resource ref="SBHN_Transfer_GetTicket/Transformations/ErrorToGetTicket"/>
                                    <con2:param name="responseError">
                                        <con2:path>$responseError</con2:path>
                                    </con2:param>
                                    <con2:param name="globalId">
                                        <con2:path>data($originalBody//GeneralInfo/GlobalId)</con2:path>
                                    </con2:param>
                                    <con2:param name="codeError">
                                        <con2:path>string($fault/ctx:errorCode/text())</con2:path>
                                    </con2:param>
                                    <con2:param name="messageError">
                                        <con2:path>string($fault/ctx:reason/text())</con2:path>
                                    </con2:param>
                                    <con2:param name="targetSystem">
                                        <con2:path>'T24'</con2:path>
                                    </con2:param>
                                    <con2:param name="status">
                                        <con2:path>'Error'</con2:path>
                                    </con2:param>
                                </con2:xqueryTransform>
                            </con1:expr>
                        </con1:replace>
                    </con:actions>
                </con:stage>
            </con:placeholder-override>
            <con:action-override id="_ActionId-N53e8b9dc.N41373bfe.0.189f609faa7.N7f47">
                <con1:assign xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                    <con1:expr>
                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">data($body//GeneralInfo/ApplicationUser)</con2:xqueryText>
                    </con1:expr>
                </con1:assign>
            </con:action-override>
        </con:template-overrides>
    </con:router>
    <con:template ref="SBHN_Transfer_Commons/PP/TransferHondurasFicohsaTemplate"/>
</con:pipelineEntry>