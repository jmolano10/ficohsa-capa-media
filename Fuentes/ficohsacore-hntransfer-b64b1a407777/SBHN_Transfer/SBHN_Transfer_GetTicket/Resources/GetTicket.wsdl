<?xml version= '1.0' encoding= 'UTF-8' ?>
<wsdl:definitions
     name="GetTicket"
     targetNamespace="https://www.ficohsa.com/regional/transfer"
     xmlns:tns="https://www.ficohsa.com/regional/transfer"
     xmlns:inp1="https://www.ficohsa.com/regional/transfer"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema"
     xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/"
     xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
    >
    <wsdl:types>
        <xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema">
            <xsd:import namespace="https://www.ficohsa.com/regional/transfer" schemaLocation="../Schemas/GetTicketTypes.xsd"/>
        </xsd:schema>
    </wsdl:types>
    <wsdl:message name="requestMessage">
        <wsdl:part name="getTicket" element="tns:getTicket"/>
    </wsdl:message>
    <wsdl:message name="replyMessage">
        <wsdl:part name="getTicketResponse" element="tns:getTicketResponse"/>
    </wsdl:message>
    <wsdl:portType name="getTicketPtt">
        <wsdl:operation name="getTicket">
            <wsdl:input message="tns:requestMessage"/>
            <wsdl:output message="tns:replyMessage"/>
        </wsdl:operation>
    </wsdl:portType>
    <wsdl:binding name="getTicketBind" type="tns:getTicketPtt">
        <soap:binding transport="http://schemas.xmlsoap.org/soap/http"/>
        <wsdl:operation name="getTicket">
            <soap:operation style="document" soapAction="getTicket"/>
            <wsdl:input>
                <soap:body use="literal" namespace="https://www.ficohsa.com/regional/transfer"/>
            </wsdl:input>
            <wsdl:output>
                <soap:body use="literal" namespace="https://www.ficohsa.com/regional/transfer"/>
            </wsdl:output>
        </wsdl:operation>
    </wsdl:binding>
</wsdl:definitions>
