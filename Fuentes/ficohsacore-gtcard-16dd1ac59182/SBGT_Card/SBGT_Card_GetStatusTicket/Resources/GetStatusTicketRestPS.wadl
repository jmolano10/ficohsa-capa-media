<application xmlns:soa="http://www.oracle.com/soa/rest" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://wadl.dev.java.net/2009/02">
   <doc title="GetStatusTicketRestPS">RestService</doc>
   <grammars>
      <xsd:schema>
            <xsd:import namespace="https://www.ficohsa.com/regional/card"
                        schemaLocation="../Schemas/GetStatusTicketTypes.xsd"/>
        </xsd:schema>
   </grammars>
   <resources>
      <resource path="/">
         <method name="POST" soa:wsdlOperation="getStatusTicket">
            <request>
               <representation mediaType="application/json" element="cns:getStatusTicket" xmlns:cns="https://www.ficohsa.com/regional/card"/>
            </request>
            <response status="200">
               <representation mediaType="application/json" element="cns:getStatusTicketResponse" xmlns:cns="https://www.ficohsa.com/regional/card"/>
            </response>
         </method>
      </resource>
   </resources>
</application>