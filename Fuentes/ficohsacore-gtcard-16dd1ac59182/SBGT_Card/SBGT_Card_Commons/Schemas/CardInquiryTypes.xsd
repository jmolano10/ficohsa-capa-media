      <xsd:sequence>
        <xsd:element name="GeneralInfo" type="ctp:GeneralInfoType"/>
        <xsd:element name="CardNumber" minOccurs="1" type="ctp:string1"/>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>
  
  <xsd:element name="getFloatingCreditCardTransactionsResponse">
        <xsd:complexType>
            <xsd:sequence>
                <xsd:element name="StatusInfo" type="ctp:StatusInfoType" minOccurs="1"/>
                <xsd:element name="ErrorInfo" type="ctp:ErrorInfoType" minOccurs="0"/>
                <xsd:element name="OwnerName" type="xsd:string" minOccurs="0"/> 
                <xsd:element name="PrincipalCardNumber" type="xsd:string" minOccurs="0"/>
                <xsd:element name="TotalLcyAmount" type="xsd:decimal" minOccurs="0"/>
                <xsd:element name="TotalUsdAmount" type="xsd:decimal" minOccurs="0"/>
                <xsd:element name="CardsDetails" type="act:CardDetails" minOccurs="0"/>
            </xsd:sequence>
        </xsd:complexType> 
    </xsd:element>
  
  
  
  
  
  <!-- Entrega 7 -->
  
  <xsd:element name="getCreditCardDetails">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="GeneralInfo" type="ctp:GeneralInfoType"/>
        <xsd:element name="CardNumber" type="ctp:string1" minOccurs="1"/>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>
  
  
  
  <xsd:element name="getCreditCardDetailsResponse">
    <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="StatusInfo" type="ctp:StatusInfoType"/>
