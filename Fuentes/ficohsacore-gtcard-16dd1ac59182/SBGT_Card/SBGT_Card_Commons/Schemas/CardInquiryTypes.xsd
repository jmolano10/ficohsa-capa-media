<xsd:schema targetNamespace="https://www.ficohsa.com/regional/card" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:act="https://www.ficohsa.com/regional/common/cardCommonType" xmlns:acc="https://www.ficohsa.com/regional/card" xmlns:ctp="https://www.ficohsa.com/regional/common/commonTypes">
  <xsd:import schemaLocation="CommonTypes.xsd" namespace="https://www.ficohsa.com/regional/common/commonTypes"/>
  <xsd:import schemaLocation="CardCommonTypes.xsd" id="CardCommonTypes" namespace="https://www.ficohsa.com/regional/common/cardCommonType"/>
  <xsd:element name="getCreditCardTransactions">
    <xsd:annotation>
      <xsd:documentation>A sample element</xsd:documentation>
    </xsd:annotation>
  <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="GeneralInfo" type="ctp:GeneralInfoType"/>
        <xsd:element name="CardNumber" minOccurs="1" type="ctp:string1"/>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>
  <xsd:element name="getCreditCardTransactionsResponse">
  <xsd:complexType>
      <xsd:sequence>
      <xsd:element name="StatusInfo" type="ctp:StatusInfoType"/>
      <xsd:element name="ErrorInfo" minOccurs="0" type="ctp:ErrorInfoType"/>
      <xsd:element name="OwnerName" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CardNumber" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CreditLimit" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CreditLimitCcy" type="xsd:string" minOccurs="0"/>
      <xsd:element name="PreviousBalanceLcy" type="xsd:string" minOccurs="0"/>
      <xsd:element name="PreviousBalanceFcy" type="xsd:string" minOccurs="0"/>
      <xsd:element name="AditionalCreditCards" minOccurs="0" type="act:AdditionalCreditCardTransactionsListInfoType"/>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>
    <xsd:element name="getCreditCardStatement">
    <xsd:annotation>
      <xsd:documentation>A sample element</xsd:documentation>
    </xsd:annotation>
  <xsd:complexType>
      <xsd:sequence>
        <xsd:element name="GeneralInfo" type="ctp:GeneralInfoType"/>
        <xsd:element name="CardNumber" minOccurs="1" type="ctp:string1"/>
      </xsd:sequence>
    </xsd:complexType>
  </xsd:element>
  <xsd:element name="getCreditCardStatementResponse">
  <xsd:complexType>
      <xsd:sequence>
      <xsd:element name="StatusInfo" type="ctp:StatusInfoType"/>
      <xsd:element name="ErrorInfo" type="ctp:ErrorInfoType" minOccurs="0"/>
      <xsd:element name="CustomerName" type="xsd:string" minOccurs="0"/>
      <xsd:element name="MainCardNumber" type="xsd:string" minOccurs="0"/>
      <xsd:element name="AccountNumber" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CutoffDate" type="xsd:string" minOccurs="0"/>
      <xsd:element name="PaymentLimitDate" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CreditLimit" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CreditLimitCcy" type="xsd:string" minOccurs="0"/>
      <xsd:element name="PointsAvailable" type="xsd:string" minOccurs="0"/>
      <xsd:element name="LcyPreviousBalance" type="xsd:string" minOccurs="0"/>
      <xsd:element name="LcyPeriodBalance" type="xsd:string" minOccurs="0"/>
      <xsd:element name="LcyTotalPayment" type="xsd:string" minOccurs="0"/>
      <xsd:element name="LcyMinPayment" type="xsd:string" minOccurs="0"/>
