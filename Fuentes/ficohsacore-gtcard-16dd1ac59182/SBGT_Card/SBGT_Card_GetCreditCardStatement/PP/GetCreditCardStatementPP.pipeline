                                                <con1:expr>
                                                    <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">if($errorCode = '-1' and count($RSPconTarjetaAnteriorTC/con1:RowSet/con1:Row) &lt;= 0)then(
	'NO RECORDS'
)else($errorCode)</con2:xqueryText>
                                                </con1:expr>
                                            </con1:assign>
                                            <con1:assign varName="validationMessage">
                                                <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8043e.N3248543a.0.189d6d901b3.N7fc6</con2:id>
                                                <con1:expr>
