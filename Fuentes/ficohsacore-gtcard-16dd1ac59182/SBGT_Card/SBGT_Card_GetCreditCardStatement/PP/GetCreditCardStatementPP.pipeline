                            <con1:case id="_BranchId-N53e80435.N53485fab.0.189dab0c6cb.N7df9">
                                <con1:condition>
                                    <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">$period &lt;= $paramMasterDataBeginDate</con2:xqueryText>
                                </con1:condition>
                                <con1:actions>
