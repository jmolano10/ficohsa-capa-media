                    <con:context>
                        <con1:userNsDecl prefix="con1" namespace="http://xmlns.oracle.com/pcbpel/adapter/db/sp/conTarjetaAnteriorTC" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                    </con:context>
