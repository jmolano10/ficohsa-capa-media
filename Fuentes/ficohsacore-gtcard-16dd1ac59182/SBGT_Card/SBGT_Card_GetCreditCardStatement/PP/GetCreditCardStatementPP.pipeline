                                <con1:condition>
                                    <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">$routeName = 'MASTER_DATA'</con2:xqueryText>
                                </con1:condition>
                                <con1:actions>
                                    <con1:wsCallout>
                                        <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8043e.N3248543a.0.189d6d901b3.N7fb4</con2:id>
                                        <con1:service ref="SBGT_Card_GetCreditCardStatement/BS/conInfoHistoricaTC" xsi:type="ref:BusinessServiceRef" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
                                        <con1:operation>conInfoHistoricaTC</con1:operation>
                                        <con1:request>
                                            <con1:body wrapped="false">REQconInfoHistoricaTC</con1:body>
                                        </con1:request>
                                        <con1:response>
                                            <con1:body wrapped="false">RSPconInfoHistoricaTC</con1:body>
                                        </con1:response>
                                        <con1:requestTransform>
