                        <con1:userNsDecl prefix="wsin" namespace="http://alcance.local/wsinfotarjetas/" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                        <con1:userNsDecl prefix="con2" namespace="http://xmlns.oracle.com/pcbpel/adapter/db/sp/conTransaccionesHistorica" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
