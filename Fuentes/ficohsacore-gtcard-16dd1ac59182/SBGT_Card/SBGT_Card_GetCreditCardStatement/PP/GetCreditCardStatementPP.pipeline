            <con:placeholder-override id="PlaceholderID_N3f578794.Ned50906.0.189993e9878.N7f21">
                <con:stage id="_StageId-N53e8043e.N3248543a.0.189d6d901b3.N7ff1" name="ConsultaParametrizacion">
                    <con:context>
                        <con1:userNsDecl prefix="ns2" namespace="https://www.ficohsa.com/regional/utility/constants" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                        <con1:userNsDecl prefix="card" namespace="https://www.ficohsa.com/regional/card" xmlns:con1="http://www.bea.com/wli/sb/stages/config"/>
                    </con:context>
                    <con:actions>
                        <con1:assign varName="cardNumber" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8043e.N3248543a.0.189d6d901b3.N7fee</con2:id>
                            <con1:expr>
                                <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">$body/card:getCreditCardStatement/CardNumber/text()</con2:xqueryText>
                            </con1:expr>
                        </con1:assign>
                        <con1:assign varName="codigoPais" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8043e.N3248543a.0.189d6d901b3.N7fe5</con2:id>
                            <con1:expr>
                                <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                    <con2:resource ref="SBGT_Card_Commons/Transformations/convertirCodigoPais"/>
                                    <con2:param name="sentidoConversion">
                                        <con2:path>'OSB-ISO3'</con2:path>
                                    </con2:param>
                                    <con2:param name="codigoPais">
                                        <con2:path>$body/card:getCreditCardStatement/GeneralInfo/SourceBank/text()</con2:path>
                                    </con2:param>
                                </con2:xqueryTransform>
                            </con1:expr>
                        </con1:assign>
                        <con1:assign varName="period" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e80435.N53485fab.0.189dab0c6cb.N7df6</con2:id>
                            <con1:expr>
                                <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">fn-bea:date-to-string-with-format("yyyyMM", current-date())</con2:xqueryText>
                            </con1:expr>
                        </con1:assign>
                        <con1:assign varName="paramNameMasterDataBeginDate" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8043e.N3248543a.0.189d6d901b3.N7feb</con2:id>
                            <con1:expr>
                                <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">concat('GT/Card/GetCreditCardStatement','.MASTERDATA_BEGIN_DATE')</con2:xqueryText>
                            </con1:expr>
                        </con1:assign>
                        <con1:assign varName="userName" xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e80435.N53485fab.0.189dab0c6cb.N7e2c</con2:id>
                            <con1:expr>
                                <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">concat("GT/Card/GetCreditCardStatement.",fn:lower-case(data($body//GeneralInfo/ApplicationId)))</con2:xqueryText>
                            </con1:expr>
                        </con1:assign>
                        <con1:wsCallout xmlns:con1="http://www.bea.com/wli/sb/stages/transform/config">
                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e80435.N53485fab.0.189dab0c6cb.N7e29</con2:id>
                            <con1:service ref="SBGT_Card_Commons/BS/GetParametersRestBS" xsi:type="ref:BusinessServiceRef" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
