                            <con1:request>
                                <con1:body wrapped="false">REQobtenerParametrizacion</con1:body>
                            </con1:request>
                            <con1:response>
                                <con1:body wrapped="false">RSPobtenerParametrizacion</con1:body>
                            </con1:response>
                            <con1:requestTransform>
                                <con1:assign varName="REQobtenerParametrizacion">
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e80435.N53485fab.0.189dab0c6cb.N7e26</con2:id>
                                    <con1:expr>
                                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">&lt;con:GetParameters xmlns:con="https://www.ficohsa.com/regional/utility/constants">
  &lt;con:parameterName>{fn:concat($paramNameMasterDataBeginDate, "||", $userName)}&lt;/con:parameterName>
&lt;/con:GetParameters></con2:xqueryText>
                                    </con1:expr>
                                </con1:assign>
                            </con1:requestTransform>
                            <con1:responseTransform>
                                <con1:assign varName="paramNameMasterDataBeginDate">
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e80435.N53485fab.0.189dab0c6cb.N7e07</con2:id>
                                    <con1:expr>
                                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">$RSPobtenerParametrizacion/ns2:parameters/ns2:parameter[ns2:parameterName/text()=$paramNameMasterDataBeginDate]/ns2:value/text()</con2:xqueryText>
                                    </con1:expr>
                                </con1:assign>
                                <con1:assign varName="paramUserName">
                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e80435.N53485fab.0.189dab0c6cb.N7e01</con2:id>
                                    <con1:expr>
