                                        <con1:case id="_BranchId-N53e8f56d.11820538.0.18c4b2f1bb9.N7fe3">
                                            <con1:condition>
                                                <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">fn:string($responseDebitCardOperation/status/text()) = 'SUCCESS'</con2:xqueryText>
                                            </con1:condition>
                                            <con1:actions>
                                                <con1:assign varName="t24">
                                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8f56d.11820538.0.18c4b2f1bb9.N7fbd</con2:id>
                                                    <con1:expr>
                                                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">&lt;userLoginElement xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"                  
                  xmlns="https://www.ficohsa.com/honduras/user">
  &lt;userLogin>{ if (data($responseParameters/t0:parameters/t0:parameter[1]/t0:parameterName= 'Card/CustomizeDebitCardPin.ACC.HN01')) then
              $responseParameters/t0:parameters/t0:parameter[1]/t0:value/text()
              
              else if (data($responseParameters/t0:parameters/t0:parameter[2]/t0:parameterName= 'Card/CustomizeDebitCardPin.ACC.HN01')) then
              $responseParameters/t0:parameters/t0:parameter[2]/t0:value/text()
              
              else if (data($responseParameters/t0:parameters/t0:parameter[3]/t0:parameterName= 'Card/CustomizeDebitCardPin.ACC.HN01')) then
              $responseParameters/t0:parameters/t0:parameter[3]/t0:value/text()
              
              else if (data($responseParameters/t0:parameters/t0:parameter[4]/t0:parameterName= 'Card/CustomizeDebitCardPin.ACC.HN01')) then
              $responseParameters/t0:parameters/t0:parameter[4]/t0:value/text()
              else()
  }&lt;/userLogin>
&lt;/userLoginElement></con2:xqueryText>
                                                    </con1:expr>
