                                                                                    <con1:expr>
                                                                                        <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config"><![CDATA[fn-bea:inlinedXML(fn:concat('<aut:RequestHeader  xmlns:aut="http://www.ficohsa.com.hn/middleware.services/autType">
             <Authentication>
