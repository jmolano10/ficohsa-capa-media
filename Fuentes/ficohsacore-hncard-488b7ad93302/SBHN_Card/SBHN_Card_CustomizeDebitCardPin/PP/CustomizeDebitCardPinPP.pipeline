                                                                                </con1:condition>
                                                                                <con1:actions>
                                                                                    <con1:wsCallout>
                                                                                        <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8338e.N266fda6e.0.18c880176be.N7fe6</con2:id>
                                                                                        <con1:service ref="SBHN_Card_CustomizeDebitCardPin/BS/procesaMensajeGenericoEnviadoSwitch" xsi:type="ref:BusinessServiceRef" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
                                                                                        <con1:operation>procesaMensajeGenericoEnviadoSwitch</con1:operation>
