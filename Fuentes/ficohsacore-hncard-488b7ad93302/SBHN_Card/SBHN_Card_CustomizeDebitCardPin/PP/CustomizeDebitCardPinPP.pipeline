                                                    <con1:responseTransform/>
                                                </con1:wsCallout>
                                                <con1:ifThenElse>
                                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e833b7.N3e1dbe82.0.18c63cf4332.N7fe7</con2:id>
                                                    <con1:case id="_BranchId-N53e833b7.N3e1dbe82.0.18c63cf4332.N7fe6">
                                                        <con1:condition>
                                                            <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">(fn:string($t24Response/Status/successIndicator/text()) = 'Success' and fn:string($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/EXTERNALMESSAGE/text()) = 'ISO')</con2:xqueryText>
                                                        </con1:condition>
                                                        <con1:actions>
                                                            <con1:assign varName="bitmapExpresion">
                                                                <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8338e.N42797b5d.0.18c828f0f23.N7fee</con2:id>
                                                                <con1:expr>
                                                                    <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config"><![CDATA[<BODY_MESSAGE_DETAILS>               
                  <ITEM>
                     <KEY>P2_PRIMARY_ACCOUNT_NUMBER</KEY>
                     <VALUE>{data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/P2PRIMARYACCOUNTNUMBER)}</VALUE>
                  </ITEM>
                  <ITEM>
                     <KEY>P7_TRANSMISSION_DATETIME</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/P7TRANSMISSIONDATETIME)} </VALUE>
                  </ITEM>
                  <ITEM>
                     <KEY>P11_SYSTEM_TRACE_AUDIT_NUMBER</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/P11SYSTRACEAUDITNUMBER) } </VALUE>
                  </ITEM>
                  <ITEM>
                     <KEY>P48_ADDITIONAL_DATA</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/P48ADDITIONALDATA) } </VALUE>
                  </ITEM>
                  <ITEM>
                     <KEY>P49_TRANSACTION_CURRENCY_CODE</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/P49TRANSACTIONCURRENCYCODE)} </VALUE>
                  </ITEM>
                  <ITEM>
                     <KEY>P60_PRODUCT_INDICATOR_DATA</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/P60PRODUCTINDICATORDATA)} </VALUE>
                  </ITEM>   
                  <ITEM>
                     <KEY>S91_FILE_UPDATE_CODE</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/S91FILEUPDATECODE)} </VALUE>
                  </ITEM>    
                  <ITEM>
                     <KEY>S101_FILE_NAME</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/S101FILENAME)} </VALUE>
                  </ITEM>   
                  <ITEM>
                     <KEY>S120_APP_FILE_TABLE_INFO</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/S120APPFILEANDTABLEINFO)} </VALUE>
                  </ITEM>   
                  <ITEM>
                     <KEY>S121_APP_FILE_TABLE_INFO</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/S121APPFILEANDTABLEINFO)} </VALUE>
                  </ITEM>                                                                                                                                                                   
                  <ITEM>
                     <KEY>S122_APP_FILE_TABLE_INFO</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/S122APPFILEANDTABLEINFO)} </VALUE>
                  </ITEM>   
                  <ITEM>
                     <KEY>S126_APP_FILE_TABLE_INFO</KEY>
                     <VALUE> { data($t24Response/FICOENQUPDPVVType/gFICOENQUPDPVVDetailType/mFICOENQUPDPVVDetailType/S126APPFILEANDTABLEINFO)} </VALUE>
                  </ITEM>                     
               </BODY_MESSAGE_DETAILS>]]></con2:xqueryText>
                                                                </con1:expr>
                                                            </con1:assign>
                                                            <con1:assign varName="positions">
                                                                <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8338e.N42797b5d.0.18c828f0f23.N7feb</con2:id>
                                                                <con1:expr>
                                                                    <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">let $positions := for $message at $i in $bitmapExpresion/ITEM
	return
		(
			if(data($message/KEY) != '') then(
				fn:replace(
					fn:substring(
						data($message/KEY), 
						2, 3), 
						"([_][a-zA-Z]*)", ""
					)
			)else()
		)
		return fn:string-join($positions, " ")</con2:xqueryText>
                                                                </con1:expr>
                                                            </con1:assign>
                                                            <con1:javaCallout varName="bitmap">
                                                                <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8338e.N42797b5d.0.18c828f0f23.N7fe8</con2:id>
