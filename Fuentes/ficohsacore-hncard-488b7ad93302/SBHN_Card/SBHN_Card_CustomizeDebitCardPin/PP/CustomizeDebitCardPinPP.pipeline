                                                <con1:wsCallout>
                                                    <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8f56d.11820538.0.18c4b2f1bb9.N7fe0</con2:id>
                                                    <con1:service ref="SBHN_Card_CustomizeDebitCardPin/BS/T24CustomizeDebitCardPin" xsi:type="ref:BusinessServiceRef" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
                                                    <con1:operation>getCustomizeDebitCardPin</con1:operation>
                                                    <con1:request>
                                                        <con1:body wrapped="false">t24Request</con1:body>
                                                    </con1:request>
                                                    <con1:response>
                                                        <con1:body wrapped="false">t24Response</con1:body>
                                                    </con1:response>
                                                    <con1:requestTransform>
                                                        <con1:replace varName="t24Request">
                                                            <con2:id xmlns:con2="http://www.bea.com/wli/sb/stages/config">_ActionId-N53e8f56d.11820538.0.18c4b2f1bb9.N7fb7</con2:id>
                                                            <con1:expr>
                                                                <con2:xqueryTransform xmlns:con2="http://www.bea.com/wli/sb/stages/config">
                                                                    <con2:resource ref="SBHN_Card_CustomizeDebitCardPin/Transformations/CustomizeDebitCardPinToT24"/>
                                                                    <con2:param name="pvv">
                                                                        <con2:path>fn:string($responseDebitCardOperation/pvv/text())</con2:path>
                                                                    </con2:param>
                                                                    <con2:param name="pass">
                                                                        <con2:path>data($userT24/ns1:password/text())</con2:path>
                                                                    </con2:param>
                                                                    <con2:param name="CustomizeDebitCardPinToT24">
                                                                        <con2:path>$body/card:customizeDebitCardPin</con2:path>
                                                                    </con2:param>
