  &lt;userLogin>{ if (data($responseParameters/t0:parameters/t0:parameter[1]/t0:parameterName= 'Card/CustomizeDebitCardPin.PIN.HN01')) then
              $responseParameters/t0:parameters/t0:parameter[1]/t0:value/text()
              
              else if (data($responseParameters/t0:parameters/t0:parameter[2]/t0:parameterName= 'Card/CustomizeDebitCardPin.PIN.HN01')) then
