<?xml version="1.0" encoding="windows-1252" ?>
<xsd:schema xmlns:xsd="http://www.w3.org/2001/XMLSchema"
            xmlns="https://www.ficohsa.com/regional/common/cardCommonType"
            targetNamespace="https://www.ficohsa.com/regional/common/cardCommonType" >
  <xsd:complexType name="AditionalCreditCardsInfoType">
    <xsd:sequence>
      <xsd:element name="CardNumber" minOccurs="0" type="xsd:string"/>
      <xsd:element name="CardHolderName" minOccurs="0" type="xsd:string"/>
      <xsd:element name="Transactions" minOccurs="0" type="TransactionsInfoListType"/>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="TransactionsInfoType">
    <xsd:sequence>
     <xsd:element name="TransactionDate" minOccurs="0" type="xsd:string"/>
      <xsd:element name="Description" type="xsd:string" minOccurs="0"/>
      <xsd:element name="Amount" type="xsd:string" minOccurs="0"/>
      <xsd:element name="Currency" type="xsd:string" minOccurs="0"/>
      <xsd:element name="TypeOfTransaction" type="xsd:string" minOccurs="0"/>
      <xsd:element name="OriginalAmount" type="xsd:string" minOccurs="0"/>
      <xsd:element name="OriginalCurrency" type="xsd:string" minOccurs="0" />
      <xsd:element name="TransPstDate" type="xsd:string" minOccurs="0"/>
      <xsd:element name="TransCode" type="xsd:string" minOccurs="0"/>
      <xsd:element name="PlanNumber" type="xsd:string" minOccurs="0"/>
      <xsd:element name="OperationCode" type="xsd:string" minOccurs="0"/>
      <xsd:element name="MovementGroup" type="xsd:string" minOccurs="0"/>
      </xsd:sequence>
  </xsd:complexType>
   <xsd:complexType name="TransactionsInfoListType">
    <xsd:sequence>
      <xsd:element name="TransactionsRecordType" minOccurs="0" maxOccurs="unbounded" type="TransactionsInfoType"/>
    </xsd:sequence>
  </xsd:complexType>
   <xsd:complexType name="AdditionalCreditCardStatementDetailsInfoType">
    <xsd:sequence>
      <xsd:element name="CardNumber" minOccurs="0" type="xsd:string"/>
      <xsd:element name="CardHolderName" minOccurs="0" type="xsd:string"/>
      <xsd:element name="AdditionalCreditCardTransactions" type="AdditionalCreditCardTransactionsStatementInfoListType"/>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="AdditionalCreditCardTransactionsStatementInfoType">
    <xsd:sequence>
      <xsd:element name="TransactionDate" type="xsd:string"/>
      <xsd:element name="Description" type="xsd:string"/>
      <xsd:element name="Amount" type="xsd:decimal"/>
      <xsd:element name="Currency" type="xsd:string"/>
      <xsd:element name="TypeOfTransaction" type="xsd:string"/>
      <xsd:element name="OriginalAmount" type="xsd:string"/>
      <xsd:element name="OriginalCurrency" type="xsd:string"/>
      <xsd:element name="OperationCode" type="xsd:string"/>
      <xsd:element name="MovementGroup" type="xsd:string"/>
    </xsd:sequence>
  </xsd:complexType>
  <xsd:complexType name="AdditionalCreditCardTransactionsInfoType">
    <xsd:sequence>
      <xsd:element name="TransactionDate" type="xsd:string" minOccurs="0" />
      <xsd:element name="Description" type="xsd:string" minOccurs="0" />
      <xsd:element name="Amount" type="xsd:decimal" minOccurs="0" />
      <xsd:element name="Currency" type="xsd:string"/>
      <xsd:element name="TypeOfTransaction" type="xsd:string" minOccurs="0" />
      <xsd:element name="OriginalAmount" type="xsd:string" minOccurs="0" />
      <xsd:element name="OriginalCurrency" type="xsd:string" minOccurs="0" />
      <xsd:element name="OperationCode" type="xsd:string" minOccurs="0" />
      <xsd:element name="MovementGroup" type="xsd:string" minOccurs="0" />
    </xsd:sequence>
  </xsd:complexType>
   <xsd:complexType name="AdditionalCreditCardInfoListType">
    <xsd:sequence>
      <xsd:element name="TransactionsRecordType" minOccurs="0" maxOccurs="unbounded" type="AdditionalCreditCardTransactionsInfoType"/>
    </xsd:sequence>
  </xsd:complexType>
   <!-- Complex Types -->
  <xsd:complexType name="CreditCardInfoType">
    <xsd:sequence>
      <xsd:element name="CardNumber" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="AccountHolderName" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CardHolderName" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CardType" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CustomerId" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="CardHolderLegalId" type="xsd:string" minOccurs="0"/>
      <xsd:element name="AccountHolderLegalId" type="xsd:string" minOccurs="0"/>
      <xsd:element name="AccountNumber" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="Product" type="xsd:string" minOccurs="0"/>
      <xsd:element name="AfinityGroup" type="xsd:string" minOccurs="0"/>
      <xsd:element name="AccountStatus" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CardStatus" type="xsd:string" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType> 
  
   <xsd:complexType name="AdditionalCreditCardTransactionsListInfoType">
    <xsd:sequence>
      <xsd:element name="CardNumber" minOccurs="0" type="xsd:string"/>
      <xsd:element name="CardHolderName" minOccurs="0" type="xsd:string"/>
      <xsd:element name="Transactions" type="AdditionalCreditCardInfoListType"/>
    </xsd:sequence>
  </xsd:complexType>
    <xsd:complexType name="AdditionalCreditCardTransactionsStatementInfoListType">
    <xsd:sequence>
      <xsd:element name="AdditionalCreditCardTransactionsRecordType" minOccurs="0" maxOccurs="unbounded" type="AdditionalCreditCardTransactionsStatementInfoType"/>
    </xsd:sequence>
  </xsd:complexType>
  
  <xsd:simpleType name="string1">
    <xsd:restriction base="xsd:string">
      <xsd:minLength value="1"/>
    </xsd:restriction>
  </xsd:simpleType>
  
  
  
  
  
  
  
  <!-- Entrega 5 -->
  
  <!-- Definiciï¿½n del tipo GetLockedFundsDetails -->
  <xsd:complexType name="GetLockedFundsDetailsType">
    <xsd:sequence>
      <xsd:element name="StartDate" type="xsd:date" minOccurs="0"/>
      <xsd:element name="LiftingDate" type="xsd:date" minOccurs="0"/>
      <xsd:element name="Description" type="xsd:string" minOccurs="0"/>
      <xsd:element name="Amount" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="LockId" type="xsd:string" minOccurs="0"/>
      <xsd:element name="DeptoId" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="DeptoName" type="xsd:string" minOccurs="0"/>
      <xsd:element name="InsuranceAmount" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="CurrentBalance" type="xsd:decimal" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType>
  
    
  <!-- Definiciï¿½n del tipo BlocksDetails -->
  <xsd:complexType name="BlocksDetails">
    <xsd:sequence>
      <xsd:element name="ValueDate" type="xsd:date"/>
      <xsd:element name="TerminalDescription" type="xsd:string"/>
      <xsd:element name="ReleaseDate" type="xsd:string" minOccurs="0"/>
      <xsd:element name="Currency" type="xsd:string"/>
      <xsd:element name="OriginalAmount" type="xsd:decimal"/>
      <xsd:element name="BlockStatus" type="xsd:string" minOccurs="0"/>
      <xsd:element name="ConfirmedAmount" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="ClearingRemainingDays" type="xsd:decimal" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType>
  
   <!-- Entrega 6 -->
  
  
   <xsd:complexType name="CardDetails">
        <xsd:sequence>
            <xsd:element name="CardNumber" type="xsd:string" minOccurs="0"/>
            <xsd:element name="LcyAmount" type="xsd:decimal" minOccurs="0"/>
            <xsd:element name="UsdAmount" type="xsd:decimal" minOccurs="0"/>
            <xsd:element name="FloatingMovements" type="FloatingMovement" minOccurs="0" maxOccurs="unbounded"/>
        </xsd:sequence>
    </xsd:complexType>

    <xsd:complexType name="FloatingMovement">
        <xsd:sequence>
            <xsd:element name="MccCode" type="xsd:string" minOccurs="0"/>
            <xsd:element name="MccDescription" type="xsd:string" minOccurs="0"/>
            <xsd:element name="Description" type="xsd:string" minOccurs="0"/>
            <xsd:element name="Date" type="xsd:date" minOccurs="0"/>
            <xsd:element name="Time" type="xsd:string" minOccurs="0"/>
            <xsd:element name="Amount" type="xsd:decimal" minOccurs="0"/>
            <xsd:element name="Currency" type="xsd:string" minOccurs="0"/>
            <xsd:element name="Fee" type="xsd:int" minOccurs="0"/>
            <xsd:element name="PaymentMethod" type="xsd:string" minOccurs="0"/>
        </xsd:sequence>
    </xsd:complexType>
  
  
  
  
   <!-- Entrega 7 -->
   
   <xsd:simpleType name="CardStatusType">
    <xsd:restriction base="xsd:string">
      <xsd:enumeration value="ISSUED"/>
      <xsd:enumeration value="RETURNED"/>
      <xsd:enumeration value="SCRAP"/>
      <xsd:enumeration value="CANCEL"/>
      <xsd:enumeration value="ACTIVE"/>
      <xsd:enumeration value="DESTROYED"/>
      <xsd:enumeration value="BLOCKED"/>
      <xsd:enumeration value="ALL"/>
      <!-- Agrega mï¿½s valores enum segï¿½n sea necesario -->
    </xsd:restriction>
  </xsd:simpleType>

   <xsd:complexType name="DebitCardCustomerRecordsType">
    <xsd:sequence>
      <xsd:element name="CardNumber" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CardHolderName" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CardCategory" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CardType" type="xsd:string" minOccurs="0"/>
      <xsd:element name="IssueDate" type="xsd:date" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType>
  
  
  <xsd:complexType name="ProductInfoType">
    <xsd:sequence>
      <xsd:element name="ProductType" type="xsd:string" minOccurs="0"/>
      <xsd:element name="Org" type="xsd:string" minOccurs="0"/>
      <xsd:element name="Currency" type="xsd:string" minOccurs="0"/>
      <xsd:element name="FinancingId" type="xsd:string" minOccurs="0"/>
      <xsd:element name="ProductNumber" type="xsd:string" minOccurs="0"/>
      <xsd:element name="TransactionDate" type="xsd:date" minOccurs="0"/>
      <xsd:element name="InicialAmount" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="Rate" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="TotalPayment" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="Term" type="xsd:string" minOccurs="0"/>
      <xsd:element name="PaymentNumber" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CurrentBalance" type="xsd:decimal" minOccurs="0"/>
      <xsd:element name="FinancingIndicator" type="xsd:string" minOccurs="0"/>
      <xsd:element name="CommerceName" type="xsd:string" minOccurs="0"/>
    </xsd:sequence>
  </xsd:complexType>

  
  
  
</xsd:schema>