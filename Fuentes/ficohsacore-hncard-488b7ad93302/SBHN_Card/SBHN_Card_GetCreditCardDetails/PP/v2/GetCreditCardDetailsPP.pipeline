                                        <con1:expr>
                                            <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">let $conCardNumber := string($RSPConDatoTarjeta/con:RowSet/con:Row[1]/con:Column[@name="numtarjeta"]/text())

return
	if($conCardNumber != "") then (
		$conCardNumber
