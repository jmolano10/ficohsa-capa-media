                                                                </con1:param>
                                                                <con1:param name="numberType">
                                                                    <con1:path>1</con1:path>
                                                                </con1:param>
                                                                <con1:param name="org">
                                                                    <con1:path>$org</con1:path>
                                                                </con1:param>
                                                            </con1:xqueryTransform>
                                                        </con2:expr>
                                                    </con2:assign>
                                                    <con2:validate>
                                                        <con1:id>_ActionId-N53e8041e.47480ce2.0.18a6da88d43.N7cbb</con1:id>
                                                        <con2:wsdl ref="SBHN_Card_GetCreditCardDetails/Resources/v1/VMX"/>
                                                        <con2:schemaElement xmlns:fdcs="http://www.procesa.com/fdcs">fdcs:EmbosserInquiryL8V6Request</con2:schemaElement>
                                                        <con2:varName>REQEmbosserInquiryL8V6</con2:varName>
                                                    </con2:validate>
                                                </con2:requestTransform>
                                                <con2:responseTransform>
                                                    <con2:assign varName="responseService">
                                                        <con1:id>_ActionId-N53e8041e.47480ce2.0.18a6da88d43.N7cba</con1:id>
                                                        <con2:expr>
                                                            <con1:xqueryText>$RSPEmbosserInquiryL8V6</con1:xqueryText>
                                                        </con2:expr>
