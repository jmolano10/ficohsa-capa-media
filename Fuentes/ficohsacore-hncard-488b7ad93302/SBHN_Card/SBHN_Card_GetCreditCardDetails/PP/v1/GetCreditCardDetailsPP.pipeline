                            <con2:case id="_BranchId-N53e8041e.47480ce2.0.18a6da88d43.N7d95">
                                <con2:condition>
                                    <con1:xqueryText>fn:string($card) != "" and $validationMessage !=''</con1:xqueryText>
                                </con2:condition>
                                <con2:actions>
                                    <con2:wsCallout>
                                        <con1:id>_ActionId-N53e8041e.47480ce2.0.18a6da88d43.N7d94</con1:id>
                                        <con2:service xsi:type="ref:BusinessServiceRef" ref="SBHN_Card_GetCreditCardDetails/BS/v1/conDatoTarjetas_v1_db" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
