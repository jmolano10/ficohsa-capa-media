	&lt;EMBOSSER_INQUIRY_RESPONSES/>
&lt;/RESULT_GROUP></con1:xqueryText>
                                        </con2:expr>
                                    </con2:assign>
                                    <con2:foreach>
                                        <con1:id>_ActionId-N53e8041e.47480ce2.0.18a6da88d43.N7cc0</con1:id>
                                        <con2:variable>DatosTarjetas_RSP</con2:variable>
                                        <con2:expression>
                                            <con1:xpathText>./con:RowSet/con:Row</con1:xpathText>
                                        </con2:expression>
                                        <con2:value-variable>item</con2:value-variable>
                                        <con2:index-variable>index</con2:index-variable>
                                        <con2:total-variable>count</con2:total-variable>
                                        <con2:actions>
                                            <con2:assign varName="org">
                                                <con1:id>_ActionId-N53e8041e.47480ce2.0.18a6da88d43.N7cbf</con1:id>
                                                <con2:expr>
                                                    <con1:xqueryText>fn:string($item/con:Column[@name = 'org']/text())</con1:xqueryText>
                                                </con2:expr>
                                            </con2:assign>
                                            <con2:assign varName="tipoOrg">
                                                <con1:id>_ActionId-N53e8041e.47480ce2.0.18a6da88d43.N7cbe</con1:id>
                                                <con2:expr>
                                                    <con1:xqueryText>fn:string($item/con:Column[@name = 'TipoOrg']/text())</con1:xqueryText>
                                                </con2:expr>
                                            </con2:assign>
                                            <con2:wsCallout>
                                                <con1:id>_ActionId-N53e8041e.47480ce2.0.18a6da88d43.N7cbd</con1:id>
                                                <con2:service xsi:type="ref:BusinessServiceRef" ref="SBHN_Card_GetCreditCardDetails/BS/v1/vmx" xmlns:ref="http://www.bea.com/wli/sb/reference"/>
                                                <con2:operation>EmbosserInquiryL8V6</con2:operation>
