                                                        <con2:expr>
                                                            <con1:xqueryText>if(string($RSPEmbosserInquiryL8V6/ServiceReturnCode/text()) != 'P')then(
	string($RSPEmbosserInquiryL8V6/fdcs:ReturnCodes/RC[1]/Code/text())
)else(
	'Success'
)</con1:xqueryText>
                                                        </con2:expr>
