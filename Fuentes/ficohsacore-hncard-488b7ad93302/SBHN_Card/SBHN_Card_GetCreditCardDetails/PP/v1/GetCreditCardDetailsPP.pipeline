                                        <con2:expr>
                                            <con1:xqueryText>let $conCardNumber := string($DatosTarjetas_RSP/con:RowSet/con:Row[1]/con:Column[@name="numtarjeta"]/text())
return
if($conCardNumber != "") then (
	$conCardNumber
) else (
	string($body/con1:consultaDatosTarjetaCredito/CARD_NUMBER/text())
)</con1:xqueryText>
                                        </con2:expr>
                                    </con2:assign>
