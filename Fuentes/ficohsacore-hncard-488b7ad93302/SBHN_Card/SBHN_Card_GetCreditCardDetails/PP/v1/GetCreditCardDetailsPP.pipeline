                                                        <con2:expr>
                                                            <con1:xqueryTransform>
                                                                <con1:resource ref="SBHN_Card_GetCreditCardDetails/Transformations/v1/embosserInquiryL8V6In"/>
                                                                <con1:param name="tipoOrg">
