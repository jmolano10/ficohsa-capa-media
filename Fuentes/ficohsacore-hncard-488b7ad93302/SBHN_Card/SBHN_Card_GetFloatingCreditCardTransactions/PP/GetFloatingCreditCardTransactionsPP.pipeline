                            <con1:expr>
                                <con2:xqueryText xmlns:con2="http://www.bea.com/wli/sb/stages/config">let $codError := $RSPconDatoTarjeta/con1:CodigoError/text() 
let $msgError := $RSPconDatoTarjeta/con1:MensajeError/text()
return 
if( $codError = '-1' and fn:normalize-space(string($msgError)) = '' ) then 'Success'
else (
  
  if(  $codError = '2' and contains($msgError, "no es Valido") ) then ('NoRecords')
  else 'Error'
)</con2:xqueryText>
