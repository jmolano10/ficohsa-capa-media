<application xmlns:soa="http://www.oracle.com/soa/rest" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://wadl.dev.java.net/2009/02">
   <doc title="GetCreditCardStatement">RestService</doc>
   <grammars>
      <xsd:schema xmlns:tns="http://xmlns.oracle.com/SBHN_Card/SBHN_Card_GetCreditCardStatement/GetCreditCardStatement" xmlns:inp1="https://www.ficohsa.com/regional/card" xmlns:soap="http://schemas.xmlsoap.org/wsdl/soap/" xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/">
            <xsd:import namespace="https://www.ficohsa.com/regional/card" schemaLocation="../../SBHN_Card_Commons/Schemas/CardInquiryTypes.xsd"/>
        </xsd:schema>
   </grammars>
   <resources>
      <resource path="/">
         <method name="POST" soa:wsdlOperation="getCreditCardStatement">
            <request>
               <representation mediaType="application/xml" element="cns:getCreditCardStatement" xmlns:cns="https://www.ficohsa.com/regional/card"/>
               <representation mediaType="application/json" element="cns:getCreditCardStatement" xmlns:cns="https://www.ficohsa.com/regional/card"/>
            </request>
            <response status="200">
               <representation mediaType="application/xml" element="cns:getCreditCardStatementResponse" xmlns:cns="https://www.ficohsa.com/regional/card"/>
               <representation mediaType="application/json" element="cns:getCreditCardStatementResponse" xmlns:cns="https://www.ficohsa.com/regional/card"/>
            </response>
         </method>
      </resource>
   </resources>
</application>